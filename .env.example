# =============================================================================
# .env.example — Plantilla de configuración del Linux Local AI Agent v2.0
# Copiá este archivo como .env y completá los valores que necesitás.
# ¡NUNCA subas el .env a git! Ya está en .gitignore.
# =============================================================================

# ── LM Studio ─────────────────────────────────────────────────────────────────
LMSTUDIO_BASE_URL=http://192.168.0.142:1234/v1
LMSTUDIO_MODEL=
LMSTUDIO_EMBED_MODEL=

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI ChatGPT ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Grok (xAI) ────────────────────────────────────────────────────────────────
GROK_API_KEY=
GROK_MODEL=grok-3-mini

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Comportamiento del agente ─────────────────────────────────────────────────
REQUIRE_CONFIRMATION=True
COMMAND_TIMEOUT=60
DEFAULT_ENGINE=local
MAX_OUTPUT_CHARS=4000

# ── Memoria semántica ─────────────────────────────────────────────────────────
MEMORY_ENABLED=True
MEMORY_TOP_K=3
MEMORY_THRESHOLD=0.75
MEMORY_MAX_ENTRIES=2000
MEMORY_SHARED_EMBED=False
# v2.0: Umbral de similitud para considerar dos memorias como duplicadas (no insertar)
MEMORY_DEDUP_THRESHOLD=0.90
# v2.0: TTL en horas para entradas tipo "log_crudo" (se auto-eliminan)
MEMORY_LOG_TTL_HOURS=24
# v2.0: El LLM consolida el episodio en un insight al terminar /task
MEMORY_CONSOLIDATE_ON_TASK=True

# ── Telegram ─────────────────────────────────────────────────────────────────
# 1. Creá un bot con @BotFather en Telegram → te da el token
# 2. Poné TELEGRAM_ENABLED=True y pegá el token
# 3. Enviá cualquier mensaje al bot → el agente registrará tu chat_id automáticamente
# 4. Anotá el chat_id que te devuelve y ponelo en TELEGRAM_ALLOWED_IDS
TELEGRAM_ENABLED=False
TELEGRAM_BOT_TOKEN=
# IDs de chats autorizados (separados por coma). Vacío = cualquiera (NO recomendado).
TELEGRAM_ALLOWED_IDS=

# ── Centinela (Modo Daemon) ───────────────────────────────────────────────────
# El centinela analiza el sistema en background y envía alertas si detecta anomalías
SENTINEL_ENABLED=False
# Intervalo entre ciclos de análisis en segundos (300 = 5 minutos)
SENTINEL_INTERVAL_SECONDS=300
# Líneas de logs a analizar por ciclo
SENTINEL_LOG_TAIL_LINES=100
# Número de anomalías para generar alerta
SENTINEL_ANOMALY_THRESHOLD=3
# URL del LLM que usa el centinela (default: LM Studio — no requiere API key)
SENTINEL_LLM_URL=
# Modelo del LLM del centinela (vacío = autodetectar)
SENTINEL_LLM_MODEL=

# ── Hosts Remotos del Centinela (Multi-Host v4.0) ────────────────────────────
# El centinela puede monitorear N hosts remotos via SSH.
# Cada host se define con el prefijo SENTINEL_HOST_N_ (N = 1, 2, 3...)
#
# Variables por host:
#   _NAME         — nombre identificador (ej: heimdall, vm-pihole)
#   _IP           — dirección IP del host
#   _USER         — usuario SSH
#   _PASS         — contraseña SSH (vacío = usar clave SSH)
#   _SSH_KEY      — ruta a clave SSH (default: ~/.ssh/id_rsa)
#   _SERVICES     — servicios systemd a verificar (separados por coma)
#   _LOG_PATHS    — rutas de logs a analizar (separados por coma)
#   _EXTRA_CHECKS — checks adicionales: zpool_status, pihole_status
#   _AUTO_REPAIR  — True = reiniciar servicios caídos automáticamente
#
# Ejemplo — Host DNS primario (PC física con ZFS):
#SENTINEL_HOST_1_NAME=heimdall
#SENTINEL_HOST_1_IP=192.168.0.152
#SENTINEL_HOST_1_USER=heimdall
#SENTINEL_HOST_1_PASS=12344321
#SENTINEL_HOST_1_SERVICES=pihole-FTL,suricata,crowdsec,nginx,unbound,evebox
#SENTINEL_HOST_1_LOG_PATHS=/mnt/heimdall-data/pihole/logs/pihole.log,/var/log/crowdsec_api.log,/var/log/nginx/error.log,/var/log/auth.log
#SENTINEL_HOST_1_EXTRA_CHECKS=zpool_status,pihole_status
#SENTINEL_HOST_1_AUTO_REPAIR=True
#
# Ejemplo — Host DNS backup (VM):
#SENTINEL_HOST_2_NAME=vm-pihole
#SENTINEL_HOST_2_IP=192.168.0.141
#SENTINEL_HOST_2_USER=pihole
#SENTINEL_HOST_2_PASS=12344321
#SENTINEL_HOST_2_SERVICES=pihole-FTL,suricata,crowdsec,nginx,unbound,evebox
#SENTINEL_HOST_2_LOG_PATHS=/var/log/pihole/pihole.log,/var/log/suricata/eve.json,/var/log/crowdsec_api.log,/var/log/nginx/error.log
#SENTINEL_HOST_2_EXTRA_CHECKS=pihole_status
#SENTINEL_HOST_2_AUTO_REPAIR=True

# ── Búsqueda Web ─────────────────────────────────────────────────────────────
WEB_SEARCH_ENABLED=True
WEB_SEARCH_MAX_RESULTS=5

# ── Herramientas Remotas ──────────────────────────────────────────────────────
# Dirección de broadcast para Wake-on-LAN
WOL_BROADCAST=192.168.0.255
# Timeout en segundos para conexiones SSH remotas
SSH_DEFAULT_TIMEOUT=30

# ── Agentic Loop ──────────────────────────────────────────────────────────────
# Máximo de errores consecutivos antes de abandonar la tarea
AGENTIC_MAX_RETRIES=5
# Si True, busca en web cuando falla un paso de bash
AGENTIC_USE_WEB_ON_FAIL=True
# Máximo de iteraciones LLM en modo /task
AGENTIC_MAX_ITERATIONS=20

# ── VM Remota (para scripts de deploy desde Windows) ─────────────────────────
VM_HOST=192.168.0.162
VM_PORT=22
VM_USER=test
VM_PASS=12344321
REMOTE_DIR=/home/test/linux_agent

# ── GitHub (para script de publicación) ──────────────────────────────────────
GITHUB_USER=Juampeeh
GITHUB_EMAIL=Juampeeh@hotmail.com
GITHUB_REPO=linux-agent
# El token PAT se pasa por CLI con --token para mayor seguridad
