# =============================================================================
# .env.example — Plantilla de configuración del Linux Local AI Agent
# Copiá este archivo como .env y completá los valores que necesitás.
# ¡NUNCA subas el .env a git! Ya está en .gitignore.
# =============================================================================

# ── LM Studio ─────────────────────────────────────────────────────────────────
# URL del servidor LM Studio (local o en red LAN)
LMSTUDIO_BASE_URL=http://192.168.0.142:1234/v1

# Modelo a usar en LM Studio (vacío = autodetectar el modelo activo en LM Studio)
LMSTUDIO_MODEL=

# Modelo de embeddings de LM Studio (vacío = usa el modelo activo para inferencia)
# Si tu instancia tiene un modelo de embeddings dedicado, ponelo aquí.
LMSTUDIO_EMBED_MODEL=

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# Modelo de embeddings de Ollama (vacío = usa OLLAMA_MODEL)
# Ejemplo con modelo dedicado: nomic-embed-text
OLLAMA_EMBED_MODEL=

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Obtené tu key gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI ChatGPT ────────────────────────────────────────────────────────────
# Obtené tu key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Grok (xAI) ────────────────────────────────────────────────────────────────
# Obtené tu key en: https://console.x.ai
GROK_API_KEY=
GROK_MODEL=grok-3-mini

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Obtené tu key en: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Comportamiento del agente ─────────────────────────────────────────────────
# True = el agente pide confirmación antes de ejecutar cada comando
# False = modo autónomo (ejecuta sin preguntar)
REQUIRE_CONFIRMATION=True

# Timeout en segundos para cada comando bash
COMMAND_TIMEOUT=60

# Motor de IA por defecto al arrancar
# Opciones: local | ollama | gemini | chatgpt | grok | claude
DEFAULT_ENGINE=local

# Máximo de caracteres de output a retornar al LLM (evita sobrecargar el contexto)
MAX_OUTPUT_CHARS=4000

# ── Memoria semántica persistente ─────────────────────────────────────────────
# True = activa la memoria vectorial entre sesiones
MEMORY_ENABLED=True

# Número de recuerdos a inyectar como contexto en cada consulta
MEMORY_TOP_K=3

# Similitud coseno mínima (0.0-1.0) para considerar un recuerdo relevante
# Subir a 0.85+ para resultados más precisos, bajar a 0.65 para más recall
MEMORY_THRESHOLD=0.75

# Máximo de entradas en la DB por proveedor (las más antiguas se auto-purgan)
MEMORY_MAX_ENTRIES=2000

# Memoria compartida entre todos los motores (True/False)
# True = usa LM Studio para embeddings en TODOS los motores (Gemini, OpenAI, etc.)
#        Todos los agentes comparten el mismo namespace vectorial "local".
#        Requiere que LM Studio esté corriendo incluso al usar motores cloud.
# False = cada motor usa su propio proveedor de embeddings (default)
#         LM Studio y Ollama comparten "local". Gemini usa "gemini". OpenAI usa "openai".
MEMORY_SHARED_EMBED=False


# ── VM Remota (para scripts de deploy desde Windows) ─────────────────────────
# Solo necesario si usás deploy_to_vm.py o github_push.py
VM_HOST=192.168.0.162
VM_PORT=22
VM_USER=test
VM_PASS=12344321
REMOTE_DIR=/home/test/linux_agent

# ── GitHub (para script de publicación) ──────────────────────────────────────
# Solo necesario si usás github_push.py
GITHUB_USER=Juampeeh
GITHUB_EMAIL=Juampeeh@hotmail.com
GITHUB_REPO=linux-agent
# El token PAT se pasa por CLI con --token para mayor seguridad
# Obtené tu token en: https://github.com/settings/tokens (scope: repo)
